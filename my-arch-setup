#!/usr/bin/env bash

# This script configures my Arch Linux setup.
# No guarantees!

set -euo pipefail

# Colors for better output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color
PROG="my_arch_setup"

info() {
  echo -e "${BLUE}[INFO]${NC} $*"
}

success() {
  echo -e "${GREEN}[SUCCESS]${NC} $*"
}

warn() {
  echo -e "${YELLOW}[WARN]${NC} $*"
}

err() {
  echo -e "${RED}[ERROR]${NC} $*" >&2
}

# Returns true/false based on users yes/no response.
ask_yn() {
  while true; do
    read -r -p "$(echo -e "${YELLOW}[?]${NC} $1 (y/n): ")" yn
    case $yn in
      [Yy]*) return 0 ;;
      [Nn]*) return 1 ;;
      *) echo "Please answer yes or no." ;;
    esac
  done
}

cmd_exists() {
  command -v "$1" &>/dev/null
}

# Check if yay is installed, offer to install if not
ensure_yay() {
  if ! cmd_exists yay; then
    warn "yay (AUR helper) is not installed."
    if ask_yn "Would you like to install yay?"; then
      info "Installing yay..."
      sudo pacman -S --needed --noconfirm git base-devel
      git clone https://aur.archlinux.org/yay.git /tmp/yay
      cd /tmp/yay
      makepkg -si --noconfirm
      cd -
      rm -rf /tmp/yay
      success "yay installed successfully!"
    else
      err "yay is required for AUR packages. Some installations will be skipped."
      return 1
    fi
  fi
  return 0
}

setup_php_composer() {
  local expected_checksum actual_checksum

  info "Installing Composer..."
  expected_checksum="$(php -r 'copy("https://composer.github.io/installer.sig", "php://stdout");')"
  php -r "copy('https://getcomposer.org/installer', 'composer-setup.php');"

  actual_checksum="$(php -r "echo hash_file('sha384', 'composer-setup.php');")"

  if [ "$expected_checksum" != "$actual_checksum" ]; then
    err "Invalid installer checksum"
    rm composer-setup.php
    return 1
  fi

  php composer-setup.php --quiet
  local result=$?
  rm composer-setup.php
  return $result
}

setup_php() {
  local php_packages=(php php-gd php-sqlite)
  if ask_yn "Install PHP packages (${php_packages[*]})?"; then
    sudo pacman -S --needed "${php_packages[@]}"
    success "PHP packages installed"
  else
    info "Skipping PHP packages..."
  fi

  if ask_yn "Install Composer?"; then
    if setup_php_composer; then
      info "Moving composer to $HOME/bin..."
      mkdir -p "$HOME/bin"
      mv composer.phar "$HOME/bin/composer"
      chmod +x "$HOME/bin/composer"
      success "Composer installed successfully"
    else
      err "Failed to install Composer"
    fi
  else
    info "Skipping Composer..."
  fi
}

setup_rofi() {
  if ask_yn "Install rofi and extensions?"; then
    sudo pacman -S --needed rofi

    if ensure_yay; then
      local aur_packages=(rofi-greenclip rofi-calc)
      for pkg in "${aur_packages[@]}"; do
        if ask_yn "Install $pkg from AUR?"; then
          yay -S --needed "$pkg"
        fi
      done
    fi
    success "Rofi setup complete"
  else
    info "Skipping rofi..."
  fi
}

setup_gitsecrets() {
  info "Setting up git-secrets..."
  info "Run these commands:"
  echo "  git clone https://github.com/awslabs/git-secrets $HOME/workspace/git-secrets"
  echo "  ln -sf $HOME/workspace/git-secrets/git-secrets $HOME/bin/git-secrets"
  read -r -p "Press Enter to continue..."
}

setup_greenclip() {
  if ask_yn "Install greenclip clipboard manager?"; then
    info "Installing greenclip from AUR..."
    if ensure_yay; then
      yay -S --needed greenclip
      success "Greenclip installed"
    fi
  else
    info "Skipping greenclip..."
  fi
}

setup_fzf() {
  if ask_yn "Install fzf (fuzzy finder)?"; then
    info "Installing fzf..."
    sudo pacman -S --needed fzf
    # Also offer the git installation for latest features
    if ask_yn "Also install latest version from git with key bindings?"; then
      git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf"
      "$HOME/.fzf/install"
    fi
    success "fzf installed"
  fi
}

install_other_packages() {
  if ask_yn "Install nvm (Node Version Manager)?"; then
    info "Installing nvm..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash
    # Source nvm to use it immediately
    export NVM_DIR="$HOME/.nvm"
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

    if ask_yn "Install latest Node.js version?"; then
      nvm install node
      success "Node.js installed"
    fi
  fi

  if ask_yn "Install autoenv?"; then
    info "Installing autoenv using npm..."
    npm install -g '@hyperupcall/autoenv'
    info "Note: You may need to update bash_profile to point to autoenv"
    read -r -p "Press Enter to continue..."
  fi
}

install_flatpak_packages() {
  if ! cmd_exists flatpak; then
    if ask_yn "Flatpak not installed. Install it?"; then
      sudo pacman -S --needed flatpak
    else
      info "Skipping Flatpak packages..."
      return
    fi
  fi

  info "Setting up Flathub repository..."
  sudo flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo

  local flathub_packages=(
    "io.gitlab.news_flash.NewsFlash"
    "com.github.johnfactotum.Foliate"
    "org.flameshot.Flameshot"
  )

  if ask_yn "Install Flatpak packages (${flathub_packages[*]})?"; then
    flatpak install -y flathub "${flathub_packages[@]}"
    info "For Flameshot, you may need to grant home directory access:"
    echo "  flatpak override --user org.flameshot.Flameshot --filesystem=~/screenshot"
    success "Flatpak packages installed"
  else
    info "Skipping Flatpak packages..."
  fi
}

setup_emacs() {
  info "Setting up Emacs..."

  if ask_yn "Install Emacs?"; then
    sudo pacman -S --needed emacs

    if ask_yn "Install Emacs from source with specific options?"; then
      info "Installing build dependencies..."
      sudo pacman -S --needed base-devel texinfo libx11 libxpm libjpeg-turbo \
        libpng giflib libtiff gtk3 ncurses gnutls

      info "
      To compile from source:
        $ git clone https://git.savannah.gnu.org/git/emacs.git
        $ cd emacs
        $ ./autogen.sh
        $ ./configure --with-mailutils
        $ make
        $ sudo make install
      "
      read -r -p "Press Enter to continue..."
    fi
    success "Emacs setup complete"
  else
    info "Skipping Emacs..."
  fi
}

setup_ctags() {
  info "Setting up universal-ctags..."

  if ask_yn "Install universal-ctags from AUR?"; then
    if ensure_yay; then
      yay -S --needed universal-ctags-git
      success "universal-ctags installed"
    fi
  else
    info "Manual installation instructions:"
    echo "  $ git clone https://github.com/universal-ctags/ctags $HOME/workspace/ctags"
    echo "  $ cd $HOME/workspace/ctags"
    echo "  $ ./autogen.sh"
    echo "  $ ./configure --prefix=$HOME/.local"
    echo "  $ make"
    echo "  $ make install"
    read -r -p "Press Enter to continue..."
  fi
}

setup_nvim() {
  info "Setting up Neovim..."

  if ask_yn "Install Neovim?"; then
    sudo pacman -S --needed neovim

    # Optional: install latest from AUR
    if ask_yn "Install neovim-nightly from AUR for latest features?"; then
      if ensure_yay; then
        yay -S --needed neovim-nightly-bin
      fi
    fi
    success "Neovim installed"
  else
    info "Skipping Neovim..."
  fi
}

setup_i3() {
  info "Setting up i3 window manager..."

  if ask_yn "Install i3?"; then
    local i3_packages=(i3-wm i3status i3lock dmenu)
    sudo pacman -S --needed "${i3_packages[@]}"

    # py3status
    if ask_yn "Install py3status (enhanced i3status)?"; then
      if ensure_yay; then
        yay -S --needed py3status-git
      else
        warn "yay not available, falling back to stable py3status"
        sudo pacman -S --needed py3status
      fi
    fi

    # Brightness control
    i3_brightness_controls

    info "Copy wallpaper to ~/.wallpaper.png"

    success "i3 setup complete"
  else
    info "Skipping i3..."
  fi
}

i3_brightness_controls() {
  info "Setting up brightness controls for i3..."

  if ask_yn "Install brightnessctl?"; then
    sudo pacman -S --needed brightnessctl
    info "Adding user to video group..."
    sudo usermod -aG video "$USER"
    success "Brightness controls configured"
    warn "You may need to log out and back in for group changes to take effect"
  fi
}

setup_gpg() {
  info "Setting up GPG..."

  sudo pacman -S --needed gnupg

  info "
  To generate a GPG key:
    $ gpg --full-generate-key

  To add to GitHub:
    1. List keys: gpg --list-secret-keys --keyid-format=long
    2. Export key: gpg --armor --export <KEY_ID>
    3. Add to GitHub: https://github.com/settings/keys

  See: https://docs.github.com/en/authentication/managing-commit-signature-verification/generating-a-new-gpg-key
  "
  read -r -p "Press Enter to continue..."
}

setup_sound() {
  info "Setting up sound system..."

  if ask_yn "Install PipeWire (modern audio system)?"; then
    local sound_packages=(
      pipewire
      pipewire-alsa
      pipewire-pulse
      pipewire-jack
      wireplumber
      pavucontrol
      bluez
      bluez-utils
      blueman
    )
    sudo pacman -S --needed "${sound_packages[@]}"

    info "Enabling Bluetooth service..."
    sudo systemctl enable bluetooth.service
    sudo systemctl start bluetooth.service

    success "Sound system configured"
    info "For more info on PipeWire setup: https://wiki.archlinux.org/title/PipeWire"
  fi
}

setup_cron_jobs() {
  info "Setting up cron jobs..."

  if ! cmd_exists cronie; then
    if ask_yn "Install cronie (cron daemon)?"; then
      sudo pacman -S --needed cronie
      sudo systemctl enable cronie.service
      sudo systemctl start cronie.service
    fi
  fi

  info "Example cron jobs:"
  echo "  # Renewal script (everyday at 10am)"
  echo "  0 10 * * * /home/sidsub/miniconda3/bin/python3 /home/sidsub/Dropbox/notes/finance/mandelbrot/fetch.py --ledger-file-path /home/sidsub/Dropbox/notes/finance/ledger.dat --ledger-price-db-update --price-db-path /home/sidsub/Dropbox/notes/finance/ledger-files/prices.db > /home/sidsub/Dropbox/notes/finance/mandelbrot/fetch.log 2>&1"
  echo ""
  echo "  # Ledger updates"
  echo "  [your ledger command here]"
  echo ""
  info "Run 'crontab -e' to edit your cron jobs"
  read -r -p "Press Enter to continue..."
}

setup_rustup() {
  if cmd_exists rustup; then
    info "Rustup already installed, updating..."
    rustup update
    return 0
  fi

  info "Installing Rustup..."
  if ask_yn "Install Rust via rustup?"; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs -o /tmp/rust.sh
    bash /tmp/rust.sh -y
    source "$HOME/.cargo/env"
    success "Rust installed successfully"
  else
    info "Skipping Rust installation..."
  fi
}

install_cargo_packages() {
  if ! cmd_exists cargo; then
    warn "Cargo not found. Install Rust first."
    return 1
  fi

  local cargo_packages=(alacritty ripgrep fd-find du-dust)

  if ask_yn "Install Rust packages (${cargo_packages[*]})?"; then
    for pkg in "${cargo_packages[@]}"; do
      info "Installing $pkg..."
      cargo install "$pkg"
    done
    success "Cargo packages installed"
  else
    info "Skipping Cargo packages..."
  fi
}

setup_ledger() {
  info "Setting up ledger-cli..."

  if ask_yn "Install ledger from AUR?"; then
    if ensure_yay; then
      yay -S --needed ledger
      success "Ledger installed from AUR"
    fi
  else
    info "Manual installation instructions:"
    echo "  $ git clone https://github.com/ledger/ledger"
    echo "  $ cd ledger"
    echo "  $ ./acprep update --prefix=\$HOME/.local"
    echo "  $ ./acprep make"
    echo "  $ ./acprep install"
    info "See: https://github.com/ledger/ledger"
    read -r -p "Press Enter to continue..."
  fi
}

install_aur_packages() {
  if ensure_yay; then
    local aur_packages=(libappindicator brave-bin man-db bash-completion signal-desktop virtualbox timeshift)
    if ask_yn "Install (${#aur_packages[@]} packages) from AUR?"; then
      yay -S --needed "${aur_packages[@]}"
    fi
  fi
}

