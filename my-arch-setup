  fi

  local pacman_packages=(
    curl
    inetutils
    wget
    git
    xdotool
    feh
    scrot
    gimp
    pavucontrol
    autoconf
    flatpak
    pass
    gnupg
    cmake
    gcc
    pkg-config
    lua
    luarocks
    ffmpeg
    imagemagick
    hyperfine
    powertop
    xournalpp
    arandr
    nemo
    net-tools
    screen
    libqalculate
    tmux
    stow
    speedtest-cli
    inotify-tools
    sqlite
    htop
    vlc
    go
    discord
  )

  if ask_yn "Install base packages (${#pacman_packages[@]} packages)?"; then
    sudo pacman -S --needed "${pacman_packages[@]}"
