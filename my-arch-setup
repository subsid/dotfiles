  install_flatpak_packages

  # Manual setup
  manual_setup_packages

  # Setup tools
  run_setup_scripts

  success "
  ╔═══════════════════════════════════════════════════════════════╗
  ║                    Setup Complete! 🎉                         ║
  ║                                                                ║
  ║  Please restart your terminal (or re-login) for all changes   ║
  ║  to take effect.                                               ║
  ╚═══════════════════════════════════════════════════════════════╝
  "
}

usage() {
  info "
  ╔═══════════════════════════════════════════════════════════════╗
  ║              Arch Linux Setup Script - Usage                  ║
  ╚═══════════════════════════════════════════════════════════════╝

  Usage: $PROG [OPTION]

  Options:
    -h, --help                  Show this help message

  Setup commands:
    --setup-rofi               Setup rofi launcher
    --setup-nvim               Setup Neovim
    --setup-gpg                Setup GPG
    --setup-sound              Setup sound system (PipeWire)
    --setup-cron-jobs          Setup cron jobs
    --setup-i3                 Setup i3 window manager
    --setup-emacs              Setup Emacs
    --setup-ctags              Setup universal-ctags
    --setup-php                Setup PHP and Composer
    --setup-gitsecrets         Setup git-secrets
    --setup-greenclip          Setup greenclip
    --setup-fzf                Setup fzf fuzzy finder
    --setup-rustup             Setup Rust toolchain
    --setup-ledger             Setup ledger-cli

  Install commands:
    --install-pacman-packages  Install base packages with pacman
    --install-aur-packages     Install AUR packages with yay
    --install-cargo-packages   Install Rust packages with cargo
    --install-other-packages   Install other packages (nvm, etc.)
    --install-flatpak-packages Install Flatpak packages
    --manual-setup-packages    Show manual setup instructions

  No arguments: Run full setup process
  "
}

# Command mapping
declare -A fns

fns["--help"]=usage
fns["-h"]=usage

# Setup commands
fns["--setup-rofi"]=setup_rofi
fns["--setup-nvim"]=setup_nvim
fns["--setup-gpg"]=setup_gpg
fns["--setup-sound"]=setup_sound
fns["--setup-cron-jobs"]=setup_cron_jobs
fns["--setup-i3"]=setup_i3
fns["--setup-emacs"]=setup_emacs
fns["--setup-ctags"]=setup_ctags
fns["--setup-php"]=setup_php
fns["--setup-gitsecrets"]=setup_gitsecrets
fns["--setup-greenclip"]=setup_greenclip
fns["--setup-fzf"]=setup_fzf
fns["--setup-rustup"]=setup_rustup
fns["--setup-ledger"]=setup_ledger

# Install commands
fns["--install-pacman-packages"]=install_pacman_packages
fns["--install-aur-packages"]=install_aur_packages
fns["--install-cargo-packages"]=install_cargo_packages
fns["--install-other-packages"]=install_other_packages
fns["--install-flatpak-packages"]=install_flatpak_packages
fns["--manual-setup-packages"]=manual_setup_packages

# Main execution
if [ $# -gt 1 ]; then
  err "Too many arguments"
  usage
  exit 1
fi

if [ $# -eq 0 ]; then
  run_setup
  exit 0
fi

if [[ -v fns[$1] ]]; then
  ${fns[$1]}
else
  err "Unknown argument: $1"
  usage
  exit 1
fi
