run_setup_scripts() {
  info "Running individual setup scripts..."

  setup_gpg
  setup_gitsecrets
  setup_greenclip
  setup_fzf
  setup_cron_jobs
  setup_sound
  setup_i3
  setup_ctags
  setup_nvim
  setup_rofi
  setup_emacs
  setup_ledger

  success "All setup scripts complete!"
}

run_setup() {
  info "
  ╔═══════════════════════════════════════════════════════════════╗
  ║                  Arch Linux Setup Script                      ║
  ║                                                                ║
  ║  This script will guide you through setting up your           ║
  ║  Arch Linux system with various tools and configurations.     ║
  ╚═══════════════════════════════════════════════════════════════╝
  "

  info "Swap ctrl and capslock if you want: setxkbmap -option \"ctrl:swapcaps\" -option \"altwin:swap_lalt_lwin\""
  info "Connect to Internet: iwctl --passphrase \"your-password\" station wlan0 connect \"your-network-name\""
  info "FIRST: Generate SSH and GPG keys"
  echo "Get a browser - pacman -S firefox"
  echo "  SSH key: https://docs.github.com/en/authentication/connecting-to-github-with-ssh"
  echo "  GPG key: https://docs.github.com/en/authentication/managing-commit-signature-verification"
  echo "TIP: You may want to install xclip (sudo pacman -S xclip) to copy stuff from CLI (cat key.pub | xclip -sel clipboard); output: xclip -sel clipboard -o"
  echo "If running in virtualbox, enabled shared clipboard in host and run the following in guest: pacman -S virtualbox-guest-utils; VBoxClient --clipboard"
  echo ""
  info "init/update git submodules:"
  echo "  $ git submodule init"
  echo "  $ git submodule update"
  read -r -p "Press Enter to continue..."

  # Ensure yay is available
  ensure_yay

  # Basics
  install_pacman_packages
  install_other_packages

  # Rust stuff
  setup_rustup
  install_cargo_packages

